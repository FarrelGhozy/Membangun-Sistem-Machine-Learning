# Alert Rule 1: High Prediction Latency
# Alert when p95 latency exceeds 1 second for 5 minutes

alert: HighPredictionLatency
expr: histogram_quantile(0.95, sum(rate(diabetes_prediction_latency_seconds_bucket[5m])) by (le)) > 1.0
for: 5m
labels:
  severity: warning
  dashboard: fazyfif
annotations:
  summary: "High prediction latency detected"
  description: "P95 latency is {{ $value }}s which exceeds 1s threshold"

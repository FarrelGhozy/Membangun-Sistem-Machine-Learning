# Alert Rule 3: Model Confidence Drop
# Alert when model confidence drops below 0.5

alert: LowModelConfidence
expr: diabetes_model_confidence < 0.5
for: 2m
labels:
  severity: warning
  dashboard: fazyfif
annotations:
  summary: "Low model confidence detected"
  description: "Model confidence is {{ $value }} which is below 0.5 threshold"
